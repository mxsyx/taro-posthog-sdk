{
    "name": "taro-posthog-sdk",
    "version": "1.0.0",
    "description": "Minimal PostHog SDK for Taro mini apps",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/mxsyx/taro-posthog-sdk.git",
        "directory": "packages/taro"
    },
    "license": "MIT",
    "main": "dist/index.cjs",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "scripts": {
        "clean": "rimraf dist coverage",
        "lint": "eslint src",
        "lint:fix": "eslint src --fix",
        "prebuild": "node -p \"'export const version = ' + JSON.stringify(require('./package.json').version)\" > src/version.ts",
        "build": "rollup -c",
        "dev": "rollup -c -w",
        "package": "pnpm pack --out $PACKAGE_DEST/%s.tgz"
    },
    "files": [
        "dist",
        "src"
    ],
    "peerDependencies": {
        "@tarojs/taro": "^4.1.4"
    },
    "devDependencies": {
        "@babel/preset-env": "catalog:",
        "@babel/preset-typescript": "catalog:",
        "@posthog-tooling/rollup-utils": "workspace:*",
        "@posthog-tooling/tsconfig-base": "workspace:*",
        "@tarojs/taro": "^4.1.4",
        "rimraf": "^6.1.2"
    },
    "keywords": [
        "posthog",
        "taro",
        "wechat",
        "miniprogram",
        "analytics"
    ]
}
